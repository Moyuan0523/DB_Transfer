# ============================================
# DB_Transfer 環境變數範本
# 複製此檔案為 .env 並填入實際連線資訊
#   cp .env.example .env
# ============================================

# ---------- 來源資料庫 (MSSQL) ----------
MSSQL_SERVER=localhost,1433
MSSQL_DATABASE=AdventureWorks2022
MSSQL_USERNAME=sa
MSSQL_PASSWORD=your_mssql_password

# ---------- 目標資料庫 (MariaDB) ----------
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=your_mariadb_password

# 轉移後的目標資料庫名稱（不存在會自動建立）
MARIADB_TARGET_DATABASE=AdventureWorks2022_Transfer
